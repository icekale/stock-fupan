<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>{{ report.title }}</title>
<style>
  :root {
    --navy:       #1B3147;
    --navy-light: #2C4A6B;
    --slate:      #3D5A73;
    --gold:       #B8963E;
    --gold-light: #D4B96A;
    --bull-red:   #C0392B;
    --bull-bg:    #FDF2F2;
    --bear-green: #27865A;
    --bear-bg:    #F2FAF5;
    --bg:         #F5F3EF;
    --card:       #FFFFFF;
    --border:     #E2DFD8;
    --text:       #2D2A26;
    --text-muted: #7A756C;
    --text-strong: #1A1714;
    --divider:    #D8D4CB;
    --table-hdr:  #1B3147;
    --table-strp: #F9F8F6;
    --tag-navy:   #E8EDF3;
    --surface-soft: #FAFAF8;
    --radius:     10px;
    --shadow:     0 12px 34px rgba(27,49,71,.08), 0 1px 2px rgba(0,0,0,.04);
    --shadow-soft: 0 6px 18px rgba(27,49,71,.05);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue", sans-serif;
    background: #EEECE8;
    color: var(--text);
    line-height: 1.76;
    font-size: 15.5px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .article-wrap {
    max-width: 1080px;
    margin: 0 auto;
    padding: 28px 24px 48px;
  }
  .article-card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 44px 54px 52px;
  }

  .header-date {
    text-align: center;
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .header-title {
    text-align: center;
    font-size: 30px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: .04em;
    margin-bottom: 6px;
  }
  .header-sub {
    text-align: center;
    font-size: 14px;
    color: var(--slate);
    border-bottom: 1px solid var(--divider);
    padding-bottom: 22px;
    margin-bottom: 32px;
  }

  .preamble {
    background: linear-gradient(135deg, #F8F7F4 0%, #F0EFEB 100%);
    border-left: 3px solid var(--gold);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 18px 22px;
    margin: 26px 0;
    font-size: 15px;
    color: var(--slate);
  }

  .section-num {
    display: inline-block;
    background: var(--navy);
    color: #FFF;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .06em;
    padding: 2px 12px;
    border-radius: 3px;
    margin-bottom: 6px;
  }
  .section-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--navy);
    margin: 8px 0 18px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--navy);
    letter-spacing: .03em;
  }
  .section-subtitle {
    font-size: 19px;
    font-weight: 700;
    color: var(--navy-light);
    margin: 30px 0 14px;
    padding-left: 12px;
    border-left: 4px solid var(--gold);
  }
  .section-sub-subtitle {
    font-size: 16px;
    font-weight: 700;
    color: var(--slate);
    margin: 22px 0 10px;
  }

  strong {
    color: var(--text-strong);
    font-weight: 600;
  }

  .bullish {
    color: var(--bull-red);
    font-weight: 600;
  }
  .bearish {
    color: var(--bear-green);
    font-weight: 600;
  }

  .card {
    background: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    margin: 18px 0;
  }

  .summary-board {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(300px, .65fr);
    gap: 18px;
    align-items: stretch;
    margin: 20px 0 8px;
  }
  .summary-main,
  .summary-side,
  .metric-card {
    background: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .summary-main {
    padding: 24px 26px;
    border-left: 4px solid var(--gold);
  }
  .summary-side {
    padding: 20px 22px;
  }
  .summary-eyebrow {
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .summary-headline {
    color: var(--navy);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.55;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin: 18px 0;
  }
  .metric-card {
    padding: 14px 16px;
    box-shadow: var(--shadow-soft);
  }
  .metric-label {
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .metric-value {
    color: var(--navy);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
  }
  .summary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sector-block {
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 2px);
    padding: 24px 24px 22px;
    margin: 24px 0;
    box-shadow: var(--shadow-soft);
  }
  .sector-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    background: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 14px;
    margin: 12px 0 18px;
    color: var(--slate);
    font-size: 14px;
  }
  .sector-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, .85fr);
    gap: 16px;
    align-items: start;
  }
  .insight-card {
    background: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    min-width: 0;
  }
  .insight-card + .insight-card {
    margin-top: 14px;
  }
  .action-card {
    border-color: #D8C28A;
    background: #FBF8F0;
  }
  .insight-label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--navy);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .insight-label::before {
    content: "";
    display: block;
    width: 18px;
    height: 2px;
    background: var(--gold);
  }

  .point-list {
    list-style: none;
    padding: 0;
  }
  .point-list li {
    position: relative;
    padding-left: 18px;
    margin-bottom: 9px;
    font-size: 15px;
    color: var(--text);
  }
  .point-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }
  .point-list li.bull::before { background: var(--bull-red); }
  .point-list li.bear::before { background: var(--bear-green); }

  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 18px 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: #FFF;
  }
  .table-wrap table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    min-width: 760px;
  }
  thead th {
    background: var(--table-hdr);
    color: #FFF;
    font-weight: 600;
    padding: 11px 12px;
    text-align: center;
    white-space: nowrap;
    font-size: 13px;
    letter-spacing: .03em;
  }
  tbody td {
    padding: 10px 12px;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }
  tbody tr:nth-child(even) td {
    background: var(--table-strp);
  }
  tbody td:first-child {
    text-align: left;
    font-weight: 500;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin: 32px 0;
  }
  .divider-dot {
    border: none;
    border-top: 1px dashed var(--border);
    margin: 24px 0;
  }

  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 4px;
    letter-spacing: .04em;
    margin-right: 4px;
  }
  .tag-bull {
    background: var(--bull-bg);
    color: var(--bull-red);
  }
  .tag-bear {
    background: var(--bear-bg);
    color: var(--bear-green);
  }
  .tag-navy {
    background: var(--tag-navy);
    color: var(--navy);
  }
  .tag-gold {
    background: #FBF8F0;
    color: #8B722E;
  }

  .conclusion-box {
    background: linear-gradient(135deg, #F8F7F3 0%, #F2F0EB 100%);
    border: 1px solid var(--gold);
    border-radius: var(--radius);
    padding: 22px 24px;
    margin: 22px 0;
  }
  .conclusion-box .label {
    font-size: 12px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .avoid-box {
    background: var(--bear-bg);
    border: 1px solid #C5E6D4;
    border-radius: var(--radius);
    padding: 18px 22px;
    margin: 18px 0;
  }
  .avoid-box .label {
    font-size: 12px;
    font-weight: 700;
    color: var(--bear-green);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .path-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin: 16px 0;
  }
  .path-node {
    background: var(--navy);
    color: #FFF;
    border-radius: 3px;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 600;
  }
  .path-arrow {
    color: var(--gold);
    font-weight: 700;
  }

  .footer-disclaimer {
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    padding: 28px 0 12px;
    border-top: 1px solid var(--divider);
    margin-top: 28px;
  }
  .footer-sources {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 16px;
    padding: 18px 20px;
    border-top: 1px solid var(--divider);
    background: var(--surface-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .footer-sources a {
    color: var(--slate);
    text-decoration: none;
    word-break: break-all;
  }
  .source-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 10px;
  }
  .source-item {
    background: #FFF;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 12px;
    min-width: 0;
  }
  .source-name {
    color: var(--navy);
    font-weight: 600;
    line-height: 1.5;
  }
  .source-meta {
    color: var(--text-muted);
    margin-top: 3px;
  }

  @media screen and (max-width: 720px) {
    body {
      font-size: 15px;
    }
    .article-wrap {
      padding: 12px;
    }
    .article-card {
      padding: 20px 14px 28px;
    }
    .header-title {
      font-size: 20px;
    }
    .section-title {
      font-size: 18px;
    }
    .section-subtitle {
      font-size: 16px;
    }
    table {
      min-width: 520px;
      font-size: 13.5px;
    }
    .summary-board,
    .metric-grid,
    .source-grid {
      grid-template-columns: 1fr;
    }
    .sector-block {
      padding: 18px 14px;
    }
    .sector-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
</head>
<body>
{% set structured = report.structured_review %}
<div class="article-wrap">
<div class="article-card">

  <div class="header-date">{{ brand_name or "STRUCTURED MARKET REVIEW" }}</div>
  <h1 class="header-title">{{ report.title }}</h1>
  <p class="header-sub">{{ structured.topic if structured else "结构复盘 · 风险分层 · 非投资建议" }}</p>

  {% if structured %}
    <div class="preamble">
      <strong>盘后 / 隔夜参考</strong> &nbsp;
      {% if structured.after_hours_news.us_market_conclusion %}
        {{ structured.after_hours_news.us_market_conclusion }}
      {% else %}
        盘后消息只作为次日观察线索，不作为单独决策依据。
      {% endif %}
      {% if structured.after_hours_news.us_market_mapping %}
        —— {{ structured.after_hours_news.us_market_mapping|join("；") }}
      {% endif %}
    </div>

    <hr class="divider">

    <span class="section-num">ZERO</span>
    <h2 class="section-title">昨日预判验证</h2>

    <div class="preamble">
      <strong>昨日预判：</strong>{{ structured.prediction_review.previous_prediction }}
    </div>

    <h3 class="section-subtitle">今日实际验证结果</h3>
    <div class="card">
      <p><strong>今日验证：</strong>{{ structured.prediction_review.actual_result }}</p>
      <p style="margin-top:10px;"><span class="tag tag-gold">修正判断</span>{{ structured.prediction_review.revision }}</p>
    </div>

    <h3 class="section-subtitle">偏差修正</h3>
    <h4 class="section-sub-subtitle"><span class="tag tag-bull">预测对的地方</span></h4>
    <ol class="point-list">
      {% for item in structured.prediction_review.correct_items %}
        <li class="bull">{{ item }}</li>
      {% endfor %}
    </ol>

    <h4 class="section-sub-subtitle"><span class="tag tag-bear">预测偏保守 / 错误的地方</span></h4>
    <ol class="point-list">
      {% for item in structured.prediction_review.missed_items %}
        <li class="bear">{{ item }}</li>
      {% endfor %}
    </ol>

    <h4 class="section-sub-subtitle">偏差原因</h4>
    <ul class="point-list">
      {% for item in structured.prediction_review.bias_reasons %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>

    <hr class="divider">

    <span class="section-num">ONE</span>
    <h2 class="section-title">先给结论</h2>

    <div class="summary-board">
      <div class="summary-main">
        <div class="summary-eyebrow">今日结论</div>
        <p class="summary-headline">{{ structured.tomorrow_judgement.core_view }}</p>
        <h3 class="section-subtitle">对明日的核心判断 · 明日观察</h3>
        <div class="table-wrap">
          <table aria-label="明日核心判断">
            <thead><tr><th style="width:22%;">观察项</th><th>方向</th></tr></thead>
            <tbody>
              <tr><td><span class="bullish">最容易继续</span></td><td style="text-align:left;">{{ structured.tomorrow_judgement.most_likely_to_continue }}</td></tr>
              <tr><td><span class="bearish">最容易分化</span></td><td style="text-align:left;">{{ structured.tomorrow_judgement.most_likely_to_diverge }}</td></tr>
              <tr><td>轮动方向</td><td style="text-align:left;">{{ structured.tomorrow_judgement.rotation_candidates|join("、") }}</td></tr>
              <tr><td>防御方向</td><td style="text-align:left;">{{ structured.tomorrow_judgement.defensive_candidates|join("、") }}</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <aside class="summary-side">
        <div class="summary-eyebrow">盘面温度</div>
        <ul class="point-list">
          {% for item in structured.tomorrow_judgement.operating_focus %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
        <div class="summary-eyebrow" style="margin-top:16px;">结构标签</div>
        <div class="summary-tags">
          {% for feature in structured.market_overview.structure_features %}
            <span class="tag tag-navy">{{ feature }}</span>
          {% endfor %}
        </div>
      </aside>
    </div>

    <hr class="divider">

    <span class="section-num">PREDICT</span>
    <h2 class="section-title">次日强势概率与观察条件</h2>

    {% if report.next_day_predictions %}
      {% for prediction in report.next_day_predictions %}
        <article class="sector-block">
          <h3 class="section-subtitle">{{ loop.index }}. {{ prediction.sector }}</h3>
          <div class="sector-meta">
            <span><strong>延续概率：</strong>
              {% if prediction.continuation_probability is not none %}
                <span class="tag tag-bull">{{ prediction.continuation_probability }}%</span>
              {% else %}
                <span class="tag tag-bear">证据不足</span>
              {% endif %}
            </span>
            <span><strong>置信度：</strong><span class="tag tag-navy">{{ prediction.confidence.value if prediction.confidence.value is defined else prediction.confidence }}</span></span>
            {% if prediction.source_basis %}
              <span><strong>复盘源：</strong>{{ prediction.source_basis|join("、") }}</span>
            {% endif %}
          </div>

          <div class="sector-grid">
            <div class="insight-card action-card">
              <div class="insight-label">概率结论</div>
              <p>{{ prediction.headline }}</p>
              {% if prediction.front_row_stocks %}
                <div class="table-wrap" style="margin-top:12px;">
                  <table aria-label="次日前排观察股">
                    <thead><tr><th style="width:28%;">前排个股</th><th>观察条件</th></tr></thead>
                    <tbody>
                      {% for stock in prediction.front_row_stocks %}
                        <tr>
                          <td><strong>{{ stock.name }}</strong>{% if stock.code %}<br>{{ stock.code }}{% endif %}</td>
                          <td style="text-align:left;">{{ stock.observation }}</td>
                        </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% endif %}
            </div>

            <div>
              <div class="insight-card">
                <div class="insight-label">触发条件</div>
                <ul class="point-list">
                  {% for item in prediction.trigger_conditions %}
                    <li>{{ item }}</li>
                  {% endfor %}
                </ul>
              </div>
              <div class="insight-card">
                <div class="insight-label">失效条件 / 风险</div>
                <ul class="point-list">
                  {% for item in prediction.invalidation_conditions %}
                    <li class="bear">{{ item }}</li>
                  {% endfor %}
                  {% for item in prediction.risk_labels %}
                    <li><span class="tag tag-bear">{{ item }}</span></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    {% else %}
      <div class="preamble">同花顺/东方财富复盘证据不足，今日不生成强势概率。</div>
    {% endif %}

    <hr class="divider">

    <span class="section-num">TWO</span>
    <h2 class="section-title">盘面总览</h2>

    <div class="metric-grid">
      {% for row in structured.market_overview.emotion_rows %}
        <div class="metric-card">
          <div class="metric-label">{{ row.label }}</div>
          <div class="metric-value">{{ row.value }}</div>
        </div>
      {% endfor %}
    </div>

    <h3 class="section-subtitle">指数数据</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>指数</th><th>收盘</th><th>涨跌幅</th></tr></thead>
        <tbody>
          {% for row in structured.market_overview.index_rows %}
            <tr>
              <td>{{ row.name }}</td>
              <td>{{ row.close }}</td>
              <td>
                <span class="{{ 'bearish' if row.change.startswith('-') else 'bullish' }}">{{ row.change }}</span>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h3 class="section-subtitle">市场情绪</h3>
    <div class="table-wrap">
      <table>
        <thead><tr><th>指标</th><th>数值</th></tr></thead>
        <tbody>
          {% for row in structured.market_overview.emotion_rows %}
            <tr><td>{{ row.label }}</td><td>{{ row.value }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h3 class="section-subtitle">市场结构特征</h3>
    <p>
      {% for feature in structured.market_overview.structure_features %}
        <span class="tag tag-navy">{{ feature }}</span>
      {% endfor %}
    </p>
    <div class="card">
      <ul class="point-list">
        {% for item in structured.market_overview.structure_notes %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
      <p style="margin-top:10px;"><strong>资金结构：</strong>{{ structured.market_overview.capital_flow_summary }}</p>
    </div>

    <hr class="divider">

    <span class="section-num">THREE</span>
    <h2 class="section-title">各板块详细分析</h2>

    {% for sector in structured.sector_reviews %}
      {% set candidate = report.sectors[loop.index0] if loop.index0 < report.sectors|length else none %}
      <article class="sector-block">
        <h3 class="section-subtitle">{{ loop.index }}. {{ sector.headline }}</h3>

        <div class="sector-meta">
          <span><strong>当前阶段：</strong>{{ sector.stage }}</span>
          <span><strong>持续性评级：</strong>
            {% if sector.sustainability == "high" %}
              <span class="tag tag-bull">高</span>
            {% elif sector.sustainability == "medium" %}
              <span class="tag tag-navy">中</span>
            {% else %}
              <span class="tag tag-bear">低</span>
            {% endif %}
          </span>
          {% if candidate and candidate.review_sources %}
            <span><strong>复盘源：</strong>{{ candidate.review_sources|join("、") }}</span>
          {% endif %}
        </div>

        <div class="sector-grid">
          <div>
            <div class="insight-card">
              <div class="insight-label">01 前排个股</div>
              {% if candidate and candidate.top_stocks %}
                <div class="table-wrap">
                  <table aria-label="前排强势个股">
                    <thead><tr><th style="width:24%;">个股</th><th style="width:16%;">涨跌幅</th><th>来源 / 标签</th></tr></thead>
                    <tbody>
                      {% for stock in candidate.top_stocks %}
                        <tr>
                          <td><strong>{{ stock.name }}</strong>{% if stock.code %}<br>{{ stock.code }}{% endif %}</td>
                          <td><span class="{{ 'bearish' if stock.pct_change < 0 else 'bullish' }}">{{ "%+.2f"|format(stock.pct_change) }}%</span></td>
                          <td style="text-align:left;">{{ stock.tags|join("、") }}</td>
                        </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% else %}
                <p>前排个股仍待复盘源确认。</p>
              {% endif %}
            </div>

            <div class="insight-card">
              <div class="insight-label">02 板块逻辑分析</div>
              <p>{{ sector.logic }}</p>
              <ul class="point-list" style="margin-top:10px;">
                {% for item in sector.logic_points %}
                  <li>{{ item }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>

          <div>
            <div class="insight-card">
              <div class="insight-label">强势 / 分歧</div>
              <ul class="point-list">
                {% for item in sector.strengths[:3] %}
                  <li class="bull">{{ item }}</li>
                {% endfor %}
                {% for item in sector.weaknesses[:2] %}
                  <li class="bear">{{ item }}</li>
                {% endfor %}
              </ul>
            </div>

            <div class="insight-card action-card">
              <div class="insight-label">03 次日动作 · 下个交易日看法</div>
              <p><strong>观察：</strong>{{ sector.next_day_view }}</p>
              <ul class="point-list" style="margin-top:10px;">
                {% for item in sector.watch_items %}
                  <li>{{ item }}</li>
                {% endfor %}
                {% for item in sector.avoid_items %}
                  <li class="bear"><strong>回避：</strong>{{ item }}</li>
                {% endfor %}
              </ul>
            </div>

            <div class="conclusion-box">
              <div class="label">持续性分析</div>
              <p>{{ sector.sustainability_analysis }}</p>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}

    <hr class="divider">

    <span class="section-num">FOUR</span>
    <h2 class="section-title">盘后 / 隔夜消息梳理</h2>

    <h3 class="section-subtitle">美股映射</h3>
    {% if structured.after_hours_news.us_market_conclusion %}
      <div class="preamble">{{ structured.after_hours_news.us_market_conclusion }}</div>
    {% endif %}
    <ul class="point-list">
      {% for item in structured.after_hours_news.us_market_mapping %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>

    <h3 class="section-subtitle">国内重要消息 / 催化</h3>
    <div class="card">
      <p><span class="tag tag-gold">重磅增量</span></p>
      <ul class="point-list" style="margin-top:10px;">
        {% for item in structured.after_hours_news.domestic_catalysts %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="avoid-box">
      <div class="label">风险提示</div>
      <ul class="point-list">
        {% for item in structured.after_hours_news.risk_notes %}
          <li class="bear">{{ item }}</li>
        {% endfor %}
      </ul>
    </div>

    <hr class="divider">

    <span class="section-num">FIVE</span>
    <h2 class="section-title">板块持续性排序</h2>

    <div class="table-wrap">
      <table>
        <thead><tr><th>排序</th><th>板块</th><th>持续性</th><th>理由</th></tr></thead>
        <tbody>
          {% for item in structured.sustainability_ranking %}
            <tr>
              <td>{{ item.rank }}</td>
              <td>{{ item.sector }}</td>
              <td>
                {% if item.rating == "high" %}
                  <span class="tag tag-bull">高</span>
                {% elif item.rating == "medium" %}
                  <span class="tag tag-navy">中</span>
                {% else %}
                  <span class="tag tag-bear">低</span>
                {% endif %}
              </td>
              <td style="text-align:left;">{{ item.reason }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <hr class="divider">

    <span class="section-num">SIX</span>
    <h2 class="section-title">资金轮动路径分析</h2>

    <h3 class="section-subtitle">实际轮动路径</h3>
    <div class="conclusion-box">
      <div class="label">关键发现</div>
      <p>{{ structured.capital_rotation.key_finding }}</p>
    </div>
    <div class="path-flow">
      {% for item in structured.capital_rotation.actual_path %}
        <span class="path-node">{{ item }}</span>{% if not loop.last %}<span class="path-arrow">→</span>{% endif %}
      {% endfor %}
    </div>
    {% if structured.capital_rotation.path_summary %}
      <p><strong>路径摘要：</strong>{{ structured.capital_rotation.path_summary }}</p>
    {% endif %}

    <h3 class="section-subtitle">关键发现</h3>
    <h4 class="section-sub-subtitle">次日路径观察</h4>
    <ul class="point-list">
      {% for item in structured.capital_rotation.next_path_watch %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>

    <hr class="divider">

    <span class="section-num">SEVEN</span>
    <h2 class="section-title">明日可介入标的与仓位建议</h2>

    <div class="preamble">
      以下内容统一表达为观察条件与仓位纪律，不构成确定性交易指令。
    </div>

    <div class="table-wrap">
      <table>
        <thead><tr><th style="width:12%;">类别</th><th style="width:30%;">观察候选</th><th>触发逻辑</th><th style="width:18%;">仓位纪律</th></tr></thead>
        <tbody>
          {% for item in structured.next_day_opportunity.focus_candidates %}
            <tr>
              <td>
                {% if loop.index == 1 %}<span class="tag tag-bull">主攻A</span>
                {% elif loop.index == 2 %}<span class="tag tag-gold">核心B</span>
                {% else %}<span class="tag tag-navy">前排C</span>
                {% endif %}
              </td>
              <td style="text-align:left;"><strong>{{ item }}</strong></td>
              <td style="text-align:left;">{{ structured.next_day_opportunity.trigger_conditions[(loop.index0 if loop.index0 < structured.next_day_opportunity.trigger_conditions|length else 0)] }}</td>
              <td>{{ structured.next_day_opportunity.position_discipline[(loop.index0 if loop.index0 < structured.next_day_opportunity.position_discipline|length else 0)] }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h4 class="section-sub-subtitle">仓位纪律</h4>
    <ul class="point-list">
      {% for item in structured.next_day_opportunity.position_discipline %}
        <li>{{ item }}</li>
      {% endfor %}
    </ul>

    <div class="avoid-box">
      <div class="label">回避条件</div>
      <ul class="point-list">
        {% for item in structured.next_day_opportunity.avoid_conditions %}
          <li class="bear">{{ item }}</li>
        {% endfor %}
      </ul>
    </div>

    {% set watch = report.watchlist_observation %}
    {% if watch %}
      <hr class="divider">
      <span class="section-num">WATCHLIST</span>
      <h2 class="section-title">自选股观察</h2>
      <p><span class="tag tag-navy">导入 {{ watch.total_count }} 只</span><span class="tag tag-gold">行情匹配 {{ watch.quote_count }} 只</span></p>
      {% if watch.strongest %}
        <h3 class="section-subtitle">强势自选</h3>
        <div class="card">
          <ul class="point-list">
            {% for item in watch.strongest %}
              <li class="bull">{{ item.symbol }} {{ item.name or '' }} {{ "%+.2f"|format(item.pct_change or 0) }}% · {{ item.reason }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      {% if watch.weakest %}
        <h3 class="section-subtitle">风险观察</h3>
        <div class="avoid-box">
          <ul class="point-list">
            {% for item in watch.weakest %}
              <li class="bear">{{ item.symbol }} {{ item.name or '' }} {{ "%+.2f"|format(item.pct_change or 0) }}% · {{ item.reason }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      {% if watch.notes %}
        <p>{{ watch.notes|join("；") }}</p>
      {% endif %}
    {% endif %}

    <hr class="divider">

    <span class="section-num">EIGHT</span>
    <h2 class="section-title">去弱留强排序</h2>

    <div class="card" style="border-left: 3px solid var(--bull-red);">
      <p style="font-weight:700; color:var(--bull-red); margin-bottom:6px;">优先保留 / 加仓观察</p>
      <ul class="point-list">
        {% for item in structured.action_discipline.focus %}
          <li class="bull">{{ item }}</li>
        {% endfor %}
      </ul>
    </div>

    <div class="avoid-box" style="margin-top:12px;">
      <div class="label">优先减仓 / 换强观察</div>
      <ul class="point-list">
        {% for item in structured.action_discipline.avoid %}
          <li class="bear">{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="conclusion-box">
      <div class="label">最终判断</div>
      <p>{{ structured.action_discipline.final_view }}</p>
    </div>

    <hr class="divider">

    <span class="section-num">NINE</span>
    <h2 class="section-title">最实战的结论</h2>

    <div class="conclusion-box" style="border: 2px solid var(--gold);">
      <div class="label">明日最优策略（一句话）</div>
      <p style="font-size:16px; font-weight:700; color:var(--navy);">{{ structured.practical_conclusion.headline }}</p>
    </div>
    <h4 class="section-sub-subtitle">最值得做的事</h4>
    <ol class="point-list">
      {% for item in structured.practical_conclusion.bullet_points %}
        <li>{{ item }}</li>
      {% endfor %}
    </ol>

    <hr class="divider">

    <span class="section-num">APPENDIX</span>
    <h2 class="section-title">上证指数中期走势研判</h2>

    <h3 class="section-subtitle">年度走势回顾与规律提取</h3>
    <div class="card">
      <ul class="point-list">
        {% for item in structured.index_mid_term_outlook.year_review %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>

    <h3 class="section-subtitle">当前位置判断</h3>
    <p>{{ structured.index_mid_term_outlook.current_position }}</p>

    <div class="table-wrap">
      <table>
        <thead><tr><th>情景</th><th>条件</th><th>应对</th></tr></thead>
        <tbody>
          {% for row in structured.index_mid_term_outlook.scenario_table %}
            <tr><td>{{ row.scenario }}</td><td>{{ row.condition }}</td><td style="text-align:left;">{{ row.response }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <div class="preamble">
      <strong>结构复盘：</strong>{{ report.narrative.conclusion }}
    </div>

    <hr class="divider">

    <span class="section-num">ONE</span>
    <h2 class="section-title">先给结论</h2>
    <div class="conclusion-box"><p>{{ report.narrative.conclusion }}</p></div>

    <span class="section-num">TWO</span>
    <h2 class="section-title">盘面总览</h2>
    <div class="card"><p>{{ report.narrative.overview }}</p></div>

    <span class="section-num">THREE</span>
    <h2 class="section-title">强势板块</h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>排名</th><th>板块</th><th>涨跌幅</th><th>原因</th></tr></thead>
        <tbody>
          {% for sector in report.sectors %}
            <tr><td>{{ sector.rank }}</td><td>{{ sector.name }}</td><td><span class="{{ 'bearish' if sector.pct_change < 0 else 'bullish' }}">{{ "%+.2f"|format(sector.pct_change) }}%</span></td><td style="text-align:left;">{{ sector.reason }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}

  {% if disclaimer_enabled %}
    <div class="footer-disclaimer">
      非投资建议，仅用于复盘研究与信息整理。
      {% if brand_footer %}<br>{{ brand_footer }}{% endif %}
    </div>
  {% elif brand_footer %}
    <div class="footer-disclaimer">{{ brand_footer }}</div>
  {% endif %}

  {% if report.news %}
    <div class="footer-sources">
      <p style="font-weight:600; margin-bottom:6px;">主要来源</p>
      <div class="source-grid">
        {% for item in report.news[:8] %}
          <div class="source-item">
            <div class="source-name">
              {% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}
            </div>
            {% if item.source or item.matched_sector %}
              <div class="source-meta">
                {% if item.source %}{{ item.source }}{% endif %}
                {% if item.source and item.matched_sector %} · {% endif %}
                {% if item.matched_sector %}{{ item.matched_sector }}{% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</div>
</div>
</body>
</html>
