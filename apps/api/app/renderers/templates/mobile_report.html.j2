<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ report.title }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f7f3ec;
      --card: #fffaf2;
      --ink: #1f1f1f;
      --muted: #71665a;
      --accent: #b42318;
      --accent-soft: #fff0ea;
      --line: #eadfce;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      line-height: 1.65;
    }
    .page {
      max-width: 720px;
      margin: 0 auto;
      padding: 28px 22px 34px;
    }
    .hero {
      padding: 28px;
      border-radius: 28px;
      background: linear-gradient(135deg, #fffaf2 0%, #fff3e7 100%);
      border: 1px solid var(--line);
      box-shadow: 0 18px 48px rgba(91, 61, 31, 0.12);
    }
    .brand {
      color: var(--accent);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin-bottom: 12px;
    }
    h1 {
      margin: 0;
      font-size: 34px;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }
    .tag {
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 13px;
      font-weight: 650;
      padding: 5px 10px;
    }
    section {
      margin-top: 18px;
      padding: 22px;
      border-radius: 24px;
      background: var(--card);
      border: 1px solid var(--line);
    }
    h2 {
      margin: 0 0 12px;
      font-size: 22px;
      letter-spacing: -0.02em;
    }
    p { margin: 0; }
    ul {
      margin: 0;
      padding-left: 20px;
    }
    li + li { margin-top: 8px; }
    .metrics {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 14px;
    }
    .metric {
      padding: 12px;
      border-radius: 16px;
      background: #ffffff;
      border: 1px solid var(--line);
    }
    .metric-label {
      color: var(--muted);
      font-size: 12px;
    }
    .metric-value {
      margin-top: 4px;
      font-size: 18px;
      font-weight: 800;
    }
    .sector {
      padding: 14px 0;
      border-top: 1px solid var(--line);
    }
    .sector:first-of-type { border-top: 0; }
    .sector-title {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      font-weight: 800;
    }
    .sector-meta {
      color: var(--accent);
      font-size: 14px;
      white-space: nowrap;
    }
    .sector-reason {
      color: var(--muted);
      margin-top: 6px;
      font-size: 14px;
    }
    .footer {
      color: var(--muted);
      margin-top: 18px;
      text-align: center;
      font-size: 13px;
    }
    .disclaimer {
      color: var(--muted);
      margin-top: 10px;
      text-align: center;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="hero">
      {% if brand_name %}<div class="brand">{{ brand_name }}</div>{% endif %}
      <h1>{{ report.title }}</h1>
      {% if report.market_state_tags %}
        <div class="tags">
          {% for tag in report.market_state_tags %}
            <span class="tag">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </header>

    <section>
      <h2>先给结论</h2>
      <p>{{ report.narrative.conclusion }}</p>
    </section>

    <section>
      <h2>盘面总览</h2>
      <p>{{ report.narrative.overview }}</p>
      <div class="metrics">
        <div class="metric">
          <div class="metric-label">上涨 / 下跌</div>
          <div class="metric-value">{{ report.breadth.up_count }} / {{ report.breadth.down_count }}</div>
        </div>
        <div class="metric">
          <div class="metric-label">涨停 / 跌停</div>
          <div class="metric-value">{{ report.breadth.limit_up_count }} / {{ report.breadth.limit_down_count }}</div>
        </div>
        <div class="metric">
          <div class="metric-label">成交额</div>
          <div class="metric-value">{{ "%.0f"|format(report.turnover_cny) }} 亿</div>
        </div>
        <div class="metric">
          <div class="metric-label">指数数量</div>
          <div class="metric-value">{{ report.indices|length }}</div>
        </div>
      </div>
    </section>

    <section>
      <h2>强势板块</h2>
      {% for sector in report.sectors %}
        <article class="sector">
          <div class="sector-title">
            <span>{{ sector.rank }}. {{ sector.name }}</span>
            <span class="sector-meta">{{ "%+.2f"|format(sector.pct_change) }}% · {{ "%.1f"|format(sector.score) }}分</span>
          </div>
          <div class="sector-reason">{{ sector.reason }}</div>
          {% if sector.news_summaries %}
            <ul>
              {% for summary in sector.news_summaries %}
                <li>{{ summary }}</li>
              {% endfor %}
            </ul>
          {% endif %}
        </article>
      {% endfor %}
    </section>

    <section>
      <h2>观察清单</h2>
      {% if report.narrative.watchlist %}
        <ul>
          {% for item in report.narrative.watchlist %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p>暂无观察项。</p>
      {% endif %}
    </section>

    <section>
      <h2>明日关注与风险</h2>
      <p>{{ report.narrative.tomorrow }}</p>
      {% if report.narrative.risks %}
        <ul>
          {% for risk in report.narrative.risks %}
            <li>{{ risk }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </section>

    {% if brand_footer %}<div class="footer">{{ brand_footer }}</div>{% endif %}
    {% if disclaimer_enabled %}<div class="disclaimer">非投资建议，仅用于复盘研究与信息整理。</div>{% endif %}
  </main>
</body>
</html>
